# LLM provider (claude / openai / gemini / ollama / openrouter)
LLM_PROVIDER=ollama
LLM_API_KEY=

# Per-task model overrides (optional, falls back to LLM_MODEL)
EXTRACT_MODEL=qwen3:8b
REVIEW_MODEL=qwen3:8b

# Ollama (used when LLM_PROVIDER=ollama) — local only
OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter (used when LLM_PROVIDER=openrouter) — works on Railway
OPENROUTER_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Telegram webhook secret token (registered when calling setWebhook)
TELEGRAM_WEBHOOK_SECRET=change-me

# Notification provider (telegram / slack / discord)
NOTIFICATION_PROVIDER=telegram

# Database
DATABASE_URL=postgresql://snap:snap@localhost:15432/snap_vocab

# API authentication (for browser extension)
API_SECRET_KEY=change-me-to-a-long-random-string
