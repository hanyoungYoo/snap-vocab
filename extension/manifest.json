{
  "manifest_version": 3,
  "name": "snap-vocab Capture",
  "version": "0.1.0",
  "description": "LLM 대화에서 영어 표현을 캡처해 학습 카드로 저장",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"]
    }
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" }
}
