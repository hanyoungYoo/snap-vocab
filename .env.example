# LLM provider (claude / openai / gemini / ollama / openrouter)
# For production (Railway): use "openrouter" or "claude"
# For local development only: use "ollama" (requires Ollama running on host)
LLM_PROVIDER=openrouter
LLM_API_KEY=

# Per-task model overrides
# openrouter examples: google/gemma-4-31b-it:free, meta-llama/llama-3.3-70b-instruct:free
# ollama examples (local only): qwen3:8b, gemma3:9b
EXTRACT_MODEL=google/gemma-4-31b-it:free
REVIEW_MODEL=google/gemma-4-31b-it:free

# OpenRouter API key (used when LLM_PROVIDER=openrouter) — works in all environments
OPENROUTER_API_KEY=

# Ollama base URL (used when LLM_PROVIDER=ollama) — LOCAL DEVELOPMENT ONLY
# Ollama cannot be reached from Railway or any remote server
OLLAMA_BASE_URL=http://localhost:11434

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Telegram webhook secret token (registered when calling setWebhook)
TELEGRAM_WEBHOOK_SECRET=change-me

# Notification provider (telegram / slack / discord)
NOTIFICATION_PROVIDER=telegram

# Database
DATABASE_URL=postgresql://snap:snap@localhost:15432/snap_vocab

# API authentication (for browser extension)
API_SECRET_KEY=change-me-to-a-long-random-string
