# LLM 설정 (claude / openai / gemini / ollama)
LLM_PROVIDER=claude
LLM_API_KEY=

# 단계별 모델 (없으면 LLM_MODEL 사용)
EXTRACT_MODEL=claude-haiku-4-5-20251001
REVIEW_MODEL=claude-sonnet-4-6

# 텔레그램
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 알림 봇 (telegram / slack / discord)
NOTIFICATION_PROVIDER=telegram

# DB
DATABASE_URL=postgresql://snap:snap@localhost:5432/snap_vocab

# 복습 알림 (KST, 24h)
REVIEW_TIME=21:00
REVIEW_MAX_CARDS=5

# API 인증 (브라우저 확장용)
API_SECRET_KEY=change-me-to-a-long-random-string
